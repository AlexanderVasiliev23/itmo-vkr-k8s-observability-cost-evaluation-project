# =============================================================================
# DockerHub
# =============================================================================

# DockerHub namespace (username или org). Обязательно для запуска в YC.
# Образы будут пушиться как <namespace>/metrics-provider:dev-xxx и т.д.
OBS_BENCH_DOCKERHUB_NAMESPACE=dockerhub_username

# =============================================================================
# Storage
# =============================================================================

# DSN для SQLite-базы результатов. По умолчанию: file:../data/obs_bench_results.db?cache=shared&mode=rwc
# OBS_BENCH_STORAGE_DSN=file:../data/obs_bench_results.db?cache=shared&mode=rwc

# Включить SQL-лог (1 или true)
# OBS_BENCH_SQL_DEBUG=false

# =============================================================================
# Namespaces (опционально, ниже приведены дефолты)
# =============================================================================

# OBS_BENCH_MONITORING_NAMESPACE=monitoring
# OBS_BENCH_METRICS_PROVIDER_NAMESPACE=metrics-provider
# OBS_BENCH_LOG_PRODUCER_NAMESPACE=log-producer
# OBS_BENCH_PROMETHEUS_TARGET_NAMESPACE=prometheus
# OBS_BENCH_VICTORIA_TARGET_NAMESPACE=victoria-metrics
# OBS_BENCH_LOKI_TARGET_NAMESPACE=loki
# OBS_BENCH_OPENSEARCH_TARGET_NAMESPACE=opensearch

# =============================================================================
# Имена сервисов (опционально, ниже приведены дефолты)
# =============================================================================

# OBS_BENCH_PROMETHEUS_RELEASE=prometheus
# OBS_BENCH_VM_SINGLE_SERVICE=vmsingle-victoria-metrics-k8s-stack
# OBS_BENCH_LOKI_QUERY_SERVICE=loki
# OBS_BENCH_OPENSEARCH_QUERY_SERVICE=opensearch-cluster-master
# OBS_BENCH_CENTRAL_PROMETHEUS_SERVICE=

# =============================================================================
# Локальные порты для port-forward (опционально)
# =============================================================================

# OBS_BENCH_PROMETHEUS_QUERY_LOCAL_PORT=9090
# OBS_BENCH_VICTORIA_QUERY_LOCAL_PORT=8428
# OBS_BENCH_LOKI_QUERY_LOCAL_PORT=3100
# OBS_BENCH_OPENSEARCH_QUERY_LOCAL_PORT=9200
